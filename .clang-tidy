# XMMS Resurrection Project — clang-tidy configuration
# https://clang.llvm.org/extra/clang-tidy/

---
# Enable a curated set of checks appropriate for the GTK/GLib C codebase.
# We deliberately exclude checks that fire heavily on pre-existing GTK2 code
# until the migration milestones are reached (tracked via GH issues).

Checks: >
  -*,
  bugprone-*,
  -bugprone-easily-swappable-parameters,
  cert-*,
  -cert-dcl37-c,
  -cert-dcl51-cpp,
  clang-analyzer-*,
  -clang-analyzer-valist.Uninitialized,
  concurrency-*,
  cppcoreguidelines-avoid-goto,
  cppcoreguidelines-init-variables,
  misc-*,
  -misc-unused-parameters,
  -misc-header-include-cycle,  # GTK3 gtkshortcutsshortcut.h has a system-level cycle we cannot fix
  modernize-macro-to-enum,
  performance-*,
  portability-*,
  readability-braces-around-statements,
  readability-else-after-return,
  readability-function-size,
  readability-identifier-naming,
  readability-inconsistent-declaration-parameter-name,
  readability-misleading-indentation,
  readability-misplaced-array-index,
  readability-non-const-parameter,
  readability-redundant-control-flow,
  readability-redundant-preprocessor,
  readability-simplify-boolean-expr,
  readability-string-compare,
  readability-suspicious-call-argument,
  readability-uppercase-literal-suffix

# Treat these checks as errors in CI (zero-tolerance):
# NOTE: cert-err33-c, cert-err34-c, cert-str34-c, clang-analyzer-security.insecureAPI.*,
# clang-analyzer-unix.Malloc, clang-analyzer-unix.MallocSizeof,
# bugprone-assignment-in-if-condition, and bugprone-narrowing-conversions are
# removed from WarningsAsErrors because they fire extensively in pre-existing
# legacy code (configfile.c, formatter.c, titlestring.c, xmmsctrl.c) that
# predates this project. They remain enabled as warnings — errors will be
# introduced gradually as the GTK3 migration progresses (tracked in GH #3).
WarningsAsErrors: >
  bugprone-use-after-move,
  bugprone-dangling-handle,
  bugprone-infinite-loop,
  bugprone-integer-division,
  bugprone-misplaced-operator-in-strlen-in-alloc,
  bugprone-not-null-terminated-result,
  bugprone-signal-handler,
  bugprone-suspicious-memset-usage,
  bugprone-undefined-memory-manipulation,
  clang-analyzer-core.NullDereference

# Header filter: lint project headers too, skip system/GLib/GTK headers
HeaderFilterRegex: '^(?!.*/(gtk|glib|gdk|pango|cairo|X11|pixman|freetype|harfbuzz|atk|gio|gobject|gmodule|gthread))'

# Naming convention rules — must match project snake_case style
CheckOptions:
  - key:   readability-identifier-naming.FunctionCase
    value: lower_case
  - key:   readability-identifier-naming.VariableCase
    value: lower_case
  - key:   readability-identifier-naming.GlobalVariableCase
    value: lower_case
  - key:   readability-identifier-naming.MacroDefinitionCase
    value: UPPER_CASE
  - key:   readability-identifier-naming.EnumCase
    value: UPPER_CASE
  - key:   readability-identifier-naming.EnumConstantCase
    value: UPPER_CASE
  - key:   readability-identifier-naming.TypedefCase
    value: CamelCase
  - key:   readability-identifier-naming.StructCase
    value: CamelCase
  - key:   readability-function-size.LineThreshold
    value: '120'
  - key:   readability-function-size.StatementThreshold
    value: '100'
  - key:   readability-function-size.BranchThreshold
    value: '30'
  - key:   readability-function-size.ParameterThreshold
    value: '10'
