# =============================================================================
# XMMS .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# CMake build artifacts
# ---------------------------------------------------------------------------
build/
compile_commands.json
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CTestTestfile.cmake
_CPack_Packages/

# ---------------------------------------------------------------------------
# Autotools runtime artifacts (generated at ./configure time, NOT in tree)
# ---------------------------------------------------------------------------
# config.h is generated by ./configure — config.h.in is source-controlled
config.h
config.h.in~
config.status
config.log
stamp-h*
autom4te.cache/
libtool
compile
xmms-config

# Generated man pages (.1.in is source; .1 is output)
xmms.1
wmxmms.1

# Backup files autoconf/automake leave behind
configure~
Makefile~
*.orig
*.rej
*.bak

# ---------------------------------------------------------------------------
# Object code and libtool intermediates
# ---------------------------------------------------------------------------
*.o
*.lo
*.la
*.a
*.so
*.so.*
*.dylib

# libtool directories
.libs/
.deps/

# Automake/make generated Makefiles (Makefile.in and Makefile.am are src)
/Makefile
Effect/Makefile
Effect/echo_plugin/Makefile
Effect/stereo_plugin/Makefile
Effect/voice/Makefile
General/Makefile
General/ir/Makefile
General/joystick/Makefile
General/song_change/Makefile
