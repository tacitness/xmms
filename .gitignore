Input/vorbis/Makefile
Input/wav/Makefile
Output/Makefile
Output/OSS/Makefile
Output/alsa/Makefile
Output/disk_writer/Makefile
Output/esd/Makefile
Output/solaris/Makefile
Output/sun/Makefile
Visualization/Makefile
Visualization/blur_scope/Makefile
Visualization/opengl_spectrum/Makefile
Visualization/sanalyzer/Makefile
intl/Makefile
libxmms/Makefile
po/Makefile
po/Makefile.in
po/POTFILES
po/stamp-po
wmxmms/Makefile
xmms/Makefile
xmms/defskin/Makefile
xmms/stamp-h2

# libxmms sub-configure artefacts
libxmms/autom4te.cache/
libxmms/config.h
libxmms/config.h.in~
libxmms/config.log
libxmms/config.rpath
libxmms/config.status
libxmms/config.guess
libxmms/config.sub
libxmms/compile
libxmms/depcomp
libxmms/install-sh
libxmms/libtool
libxmms/ltmain.sh
libxmms/missing
